{
  "name": "postkit-ui-component-library",
  "version": "1.0.4",
  "description": "(Class Assignment) Reusable React components for displaying posts, search input, and publish status.",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "module": "./dist/index.es.js",
      "import": "./dist/index.es.js",
      "require": "./dist/index.js"
    }
  },
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.build.json",
    "test": "vitest run",
    "prepublishOnly": "npm test && npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aellantis/3310-UI-Component-Library.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Aellantis/3310-UI-Component-Library/issues"
  },
  "homepage": "https://github.com/Aellantis/3310-UI-Component-Library#readme",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "storybook": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "playwright": "^1.59.1",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4"
  }
}